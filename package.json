{
  "name": "question-pipeline",
  "version": "1.0.0",
  "private": true,
  "description": "Batch pipeline for Indian exam question extraction and JSON dataset generation",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npx tsx --env-file=.env src/index.ts",
    "scrape": "npx tsx --env-file=.env src/scrapers/nta-scraper.ts",
    "batch": "npx tsx --env-file=.env scripts/batch-process.ts",
    "status": "npx tsx --env-file=.env src/index.ts status",
    "process-pdf": "npx tsx --env-file=.env scripts/process-pdf.ts",
    "review": "npx tsx --env-file=.env src/review/review-cli.ts",
    "signoff": "npx tsx --env-file=.env src/review/batch-signoff.ts",
    "verify": "npx tsx --env-file=.env src/utils/integrity.ts",
    "stats": "npx tsx --env-file=.env scripts/stats.ts",
    "export": "npx tsx --env-file=.env scripts/export-for-opensource.ts",
    "rebuild-index": "npx tsx --env-file=.env scripts/rebuild-index.ts",
    "api": "npx tsx --env-file=.env src/api/server.ts",
    "test-models": "npx tsx --env-file=.env scripts/test-models.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-mistral": "npx tsx --env-file=.env scripts/test-mistral-structured.ts",
    "test-full-pipeline": "npx tsx --env-file=.env scripts/test-full-pipeline.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/readline-sync": "^1.4.8",
    "readline-sync": "^1.4.10",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
